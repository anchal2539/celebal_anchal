      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Week 5: Text Generation using RNN, LSTM and GRU\n",
        "## Amarjeet Kumar\n",
        "This notebook trains RNN, LSTM and GRU on five different corpora."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import tensorflow as tf\n",
        "from tensorflow.keras.preprocessing.text import Tokenizer\n",
        "from tensorflow.keras.preprocessing.sequence import pad_sequences\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Embedding,SimpleRNN,LSTM,GRU,Dense\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Student Learning Tasks\n",
        "- Embedding Dimension = 64\n- Hidden Units = 128\n- Epochs = 200\n- Generate 10 words\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def train_models(corpus):\n    tokenizer=Tokenizer()\n    tokenizer.fit_on_texts([corpus])\n    total_words=len(tokenizer.word_index)+1\n    seq=[]\n    for line in corpus.split(\"\\n\"):\n        t=tokenizer.texts_to_sequences([line])[0]\n        for i in range(1,len(t)):\n            seq.append(t[:i+1])\n    max_len=max(len(x) for x in seq)\n    seq=pad_sequences(seq,maxlen=max_len,padding='pre')\n    X=seq[:,:-1]\n    y=seq[:,-1]\n    def build(kind):\n        m=Sequential([Embedding(total_words,64,input_length=max_len-1),\n                      kind(128),\n                      Dense(total_words,activation='softmax')])\n        m.compile(optimizer='adam',loss='sparse_categorical_crossentropy')\n        h=m.fit(X,y,epochs=200,verbose=0)\n        return m,h\n    rnn,rh=build(SimpleRNN)\n    lstm,lh=build(LSTM)\n    gru,gh=build(GRU)\n    return tokenizer,max_len,rnn,lstm,gru,rh,lh,gh\n\ndef generate_text(model,tokenizer,max_len,seed,next_words=10):\n    for _ in range(next_words):\n        t=tokenizer.texts_to_sequences([seed])[0]\n        t=pad_sequences([t],maxlen=max_len-1,padding='pre')\n        pred=np.argmax(model.predict(t,verbose=0),axis=-1)[0]\n        word=\"\"\n        for w,i in tokenizer.word_index.items():\n            if i==pred:\n                word=w\n                break\n        seed+=\" \"+word\n    return seed\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Experiment 1: Shakespeare"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "corpus = '''To be or not to be that is the question.\n",
        "All the world's a stage and all the men and women merely players.\n",
        "The course of true love never did run smooth.'''\n",
        "tokenizer,max_len,rnn,lstm,gru,rh,lh,gh=train_models(corpus)\n",
        "\n",
        "plt.figure(figsize=(8,4))\n",
        "plt.plot(rh.history['loss'],label='RNN')\n",
        "plt.plot(lh.history['loss'],label='LSTM')\n",
        "plt.plot(gh.history['loss'],label='GRU')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "print(generate_text(rnn,tokenizer,max_len,'to be',10))\n",
        "print(generate_text(lstm,tokenizer,max_len,'to be',10))\n",
        "print(generate_text(gru,tokenizer,max_len,'to be',10))\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Experiment 2: Song Lyrics"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "corpus = '''The morning sun is shining bright.\n",
        "Birds are singing in the light.\n",
        "Dreams are flying like a kite.'''\n",
        "tokenizer,max_len,rnn,lstm,gru,rh,lh,gh=train_models(corpus)\n",
        "\n",
        "plt.figure(figsize=(8,4))\n",
        "plt.plot(rh.history['loss'],label='RNN')\n",
        "plt.plot(lh.history['loss'],label='LSTM')\n",
        "plt.plot(gh.history['loss'],label='GRU')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "print(generate_text(rnn,tokenizer,max_len,'the morning',10))\n",
        "print(generate_text(lstm,tokenizer,max_len,'the morning',10))\n",
        "print(generate_text(gru,tokenizer,max_len,'the morning',10))\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Experiment 3: Chatbot"
